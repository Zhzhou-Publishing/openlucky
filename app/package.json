{
  "name": "openlucky-app",
  "version": "v1.3.0-rc1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run update-emoji",
    "update-emoji": "node scripts/update-emoji.js",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win:portable": "npm run build && electron-builder --win portable --x64"
  },
  "keywords": [],
  "author": "ZhZhou",
  "license": "Apache-2.0",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "standard-version": "^9.5.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@twemoji/api": "^17.0.2",
    "@twemoji/svg": "^15.0.0",
    "sharp": "^0.34.5",
    "tmp": "^0.2.5",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "build": {
    "appId": "com.openlucky.desktop",
    "productName": "OpenLuckyApp",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "build-resources/emoji/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/OpenLuckyIcon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
