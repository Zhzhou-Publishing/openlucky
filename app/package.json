{
  "name": "openlucky-app",
  "version": "1.4.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron .",
    "dev:hot": "concurrently \"npm run dev\" \"npm run dev:electron\" --kill-others",
    "build": "vite build && npm run update-emoji",
    "update-emoji": "node scripts/update-emoji.js",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win:portable": "npm run build && electron-builder --win portable --x64",
    "build:mac": "npm run build && electron-builder --mac --arm64",
    "build:mac:universal": "npm run build && electron-builder --mac --universal"
  },
  "keywords": [],
  "author": "ZhZhou",
  "license": "Apache-2.0",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "standard-version": "^9.5.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@twemoji/api": "^17.0.2",
    "@twemoji/svg": "^15.0.0",
    "image-size": "^1.2.0",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "tmp": "^0.2.5",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "build": {
    "appId": "com.github.zhzhou-publishing.openlucky",
    "productName": "OpenLuckyApp",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "build-resources/emoji/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/OpenLuckyIcon.ico",
      "extraResources": [
        {
          "from": "../config.yaml",
          "to": "config.yaml"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build-resources/OpenLuckyIcon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "OpenLucky_v${version}_${platform}_${arch}.${ext}",
      "extraResources": [
        {
          "from": "../bin/openlucky",
          "to": "openlucky"
        },
        {
          "from": "../config.yaml",
          "to": "config.yaml"
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
